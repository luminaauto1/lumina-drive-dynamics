# ============================================================================
# Edge Function secrets — Lumina Drive Dynamics
# ============================================================================
# These are SERVER-SIDE secrets consumed by the Deno edge functions in
# supabase/functions/*. They are NOT Vercel variables and are NOT bundled
# into the frontend.
#
# Local development (supabase CLI):
#   cp supabase/functions/.env.example supabase/functions/.env
#   supabase functions serve --env-file supabase/functions/.env
#
# Production (hosted Supabase) — set via dashboard (Edge Functions -> Secrets)
# or CLI:
#   supabase secrets set --env-file supabase/functions/.env
#
# MIGRATION NOTE: these secrets live in the Supabase project, so they survive
# the Lovable -> Vercel move untouched. The exceptions are flagged below.
# ============================================================================

# --- Injected automatically by the Supabase platform ------------------------
# You only need these locally; hosted functions receive them automatically.
SUPABASE_URL="https://<your-project-ref>.supabase.co"
SUPABASE_ANON_KEY="<your-anon-key>"
SUPABASE_SERVICE_ROLE_KEY="<your-service-role-key>"   # NEVER expose to frontend

# --- Internal / auth --------------------------------------------------------
# Shared secret required by public (unauthenticated) endpoints; must match
# LUMINA_PUBLIC_KEY in src/lib/publicApi.ts exactly. Rotate both together.
LUMINA_INTERNAL_API_KEY="<shared-public-endpoint-key>"

# PIN gate for sensitive admin actions (verify-admin-pin function).
ADMIN_UNLOCK_PIN="<admin-pin>"

# --- Email ------------------------------------------------------------------
# Resend (transactional email: status notifications, finance alerts, invites)
RESEND_API_KEY="re_..."

# EmailJS (legacy email path used by send-email)
EMAILJS_SERVICE_ID="<emailjs-service-id>"
EMAILJS_TEMPLATE_ID="<emailjs-template-id>"
EMAILJS_PUBLIC_KEY="<emailjs-public-key>"
EMAILJS_PRIVATE_KEY="<emailjs-private-key>"

# --- AI ---------------------------------------------------------------------
# !! MIGRATION RISK !! Four functions (sales-copilot, transcribe-call,
# parse-whatsapp, analyze-business-state) call the Lovable AI Gateway
# (https://ai.gateway.lovable.dev) with this key. If you fully leave Lovable
# this key will eventually stop working — port those functions to a direct
# AI provider. See docs/MIGRATION.md "Lovable AI Gateway" section.
LOVABLE_API_KEY="<lovable-ai-gateway-key>"

# --- Social / messaging integrations ----------------------------------------
# EasySocial (WhatsApp/TikTok lead automation + webhooks)
EASYSOCIAL_API_KEY="<easysocial-api-key>"
EASYSOCIAL_APP_SECRET="<easysocial-app-secret>"
EASYSOCIAL_VERIFY_TOKEN="<easysocial-webhook-verify-token>"

# --- Google (server-side) ----------------------------------------------------
# Server keys (no referrer restriction) used by edge functions for geocoding.
GOOGLE_MAPS_API_KEY="<google-maps-server-key>"
GOOGLE_GEOCODING_API_KEY="<google-geocoding-server-key>"

# --- LuminaTaskOS (AI second-brain OS) --------------------------------------
# The running AI for TaskOS. Get from console.anthropic.com. Drives every
# taskos-* function (classification, Q&A). Direct Anthropic — NOT the Lovable
# gateway above.
ANTHROPIC_API_KEY="sk-ant-..."
# Telegram bot (one bot; each user links their own chat with a one-time code).
TELEGRAM_BOT_TOKEN="<from-@BotFather>"          # e.g. 1234567:ABC...
TELEGRAM_BOT_USERNAME="<bot-username-no-@>"      # e.g. LuminaTaskOSBot
# Random server-only secret echoed in Telegram setWebhook + checked on every
# webhook call (constant-time). Generate: openssl rand -hex 32
TELEGRAM_WEBHOOK_SECRET="<openssl rand -hex 32>"
# NOTE: TaskOS crons (reminders, daily briefing, weekly review, inbox sweep,
# priority engine) need NO extra secret. They run via pg_cron -> pg_net and
# authenticate with a random secret generated and stored entirely inside the DB
# (public.taskos_internal_config). Nothing for you to set.
#
# OPTIONAL — voice notes. The edge runtime has no built-in speech-to-text, so
# Telegram voice notes are only transcribed if this OpenAI Whisper key is set.
# Without it, voice notes are saved for manual review; everything else works.
# OPENAI_API_KEY="sk-..."
# OPENAI_STT_MODEL="whisper-1"   # optional override
