# ============================================================================
# Frontend environment variables — Lumina Drive Dynamics
# ============================================================================
# Copy to `.env` for local development:  cp .env.example .env
#
# On Vercel, set every variable below under:
#   Project Settings -> Environment Variables  (Production + Preview + Development)
#
# IMPORTANT (migration): Vite inlines VITE_* variables into the JS bundle at
# BUILD time. They are therefore PUBLIC — never put a service-role key, the
# database password, or any server-only secret in this file. Server secrets
# belong in Supabase Edge Function secrets (see supabase/functions/.env.example).
# After changing a value on Vercel you must trigger a redeploy.
# ============================================================================

# --- Supabase (required) ----------------------------------------------------
# Found in: Supabase Dashboard -> Project Settings -> API
VITE_SUPABASE_URL="https://<your-project-ref>.supabase.co"

# The anon/publishable key (safe to expose; Row Level Security enforces access).
# Lovable exports call this PUBLISHABLE_KEY; the client also accepts
# VITE_SUPABASE_ANON_KEY if you prefer the conventional name.
VITE_SUPABASE_PUBLISHABLE_KEY="<your-anon-key>"

# Project ref, used by the Supabase CLI and some tooling.
VITE_SUPABASE_PROJECT_ID="<your-project-ref>"

# --- Third-party integrations (frontend) ------------------------------------
# Google Maps JS / Places autocomplete (address fields on finance + sell-car
# forms). Restrict this key by HTTP referrer in the Google Cloud console to
# your Vercel + custom domains.
VITE_GOOGLE_MAPS_API_KEY="<your-google-maps-browser-key>"
