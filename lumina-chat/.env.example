# ---- Supabase (your own database) ----
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=YOUR-SERVICE-ROLE-KEY   # server-only, never expose to the browser

# ---- EasySocial (your existing platform / your chats) ----
ES_API_BASE=https://api.easysocial.in
ES_BUSINESS_ID=4026
ES_TOKEN=PASTE-YOUR-EASYSOCIAL-TOKEN            # web-app 'token'; prefer a proper API key for production
ES_DEVICE_ID=PASTE-DEVICE-ID
ES_USER_ID=8403

# ---- Safety switch ----
# 'true'  = engine decides & LOGS but sends NOTHING (safe testing).
# 'false' = live sends through EasySocial. Flip only after verifying the send endpoint.
ES_DRY_RUN=true

# ---- Batch button auth ----
BATCH_SECRET=make-a-long-random-string
